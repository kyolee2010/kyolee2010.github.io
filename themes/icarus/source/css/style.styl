// Theme base
@import '../../include/style/base'
@import '../../include/style/helper'
@import '../../include/style/button'
@import '../../include/style/card'
@import '../../include/style/article'
@import '../../include/style/navbar'
@import '../../include/style/footer'
@import '../../include/style/pagination'
@import '../../include/style/codeblock'
@import '../../include/style/widget'
@import '../../include/style/responsive'

/* ==========================
   Shared page layouts
   ========================== */
@media screen and (min-width: 1024px)
  .is-1-column .container
    max-width 1120px
    width calc(100% - 2rem)

.article .content .home-sections
  display: flex
  flex-direction row
  justify-content: space-between
  align-items: flex-start
  flex-wrap: wrap
  gap: 1em

.article .content .home-layout
  .home-main
    flex 1.5 1 28rem
  .home-news
    flex 1 1 18rem
    background #f8f9fa
    padding .3em .5em .2em
    border-radius 8px
    box-shadow 4px 4px 4px rgba(0,0,0,.05)
    font-size .9em

.article .content .member-layout
  .member-list
    flex 1 1 22rem
    text-align left
  .group-photos
    flex 1.2 1 24rem

.article .content figure
  margin .6rem 0 .8rem !important
  text-align center

.article .content figure img
  display block
  margin 0 auto

.article .content figure figcaption
  margin-top .25rem
  text-align center
  color #666
  font-size .95em
  font-style normal

.profile-photo img
  width 160px
  border-radius 50%

.research-figure img
  width 300px
  max-width 100%

.group-photo
  img
    width 1000px
    max-width 100%

.leader-info
  text-align center !important

.leader-title
  text-align center !important
  font-size 1.6em
  line-height 1.4
  margin .35em 0 .2em

.include-news
  margin 0 auto
  max-width 900px
  padding 0 .5em

.include-news-list
  margin 0 !important
  margin-left 0 !important
  padding-left 1em !important
  list-style-position outside !important

.include-news-year
  text-align center
  font-weight bold
  margin .2em 0 !important

.include-news-more
  text-align center !important
  margin-top .8em !important

/* =====================================
   页脚
   ===================================== */
.footer-visitors
  margin-top .2em


/* =====================================
   导航栏
   ===================================== */
.navbar-main .navbar-item
  white-space nowrap
  text-decoration none !important

.navbar-main .navbar-item:hover,
.navbar-main .navbar-item:focus,
.navbar-main .navbar-item.is-active
  text-decoration none !important

.navbar .navbar-logo
  padding 0 .2rem 0 .45rem !important
  pointer-events auto !important

.navbar .navbar-logo img
  height 26px !important
  max-height 26px !important
  vertical-align middle

.navbar .navbar-logo + .navbar-item
  padding-left .2rem !important

@media screen and (max-width: 768px)
  html,
  body
    overflow-x hidden

  .article .content .home-layout .home-main,
  .article .content .home-layout .home-news,
  .article .content .member-layout .member-list,
  .article .content .member-layout .group-photos
    flex 1 1 100%
    min-width 0

  .navbar-main .navbar-container,
  .navbar-main .navbar-menu
    width 100% !important
    max-width 100% !important
    overflow-x hidden !important

  .navbar-main .navbar-menu
    flex 1 1 100%
    flex-wrap wrap
    flex-shrink 1
    justify-content flex-start

  .navbar-main .navbar-start,
  .navbar-main .navbar-end
    display contents

  .navbar-main .navbar-item
    padding .32rem .32rem !important
    line-height 1.25

  .navbar .navbar-logo img
    height 22px !important
    max-height 22px !important

  .navbar .navbar-logo + .navbar-item
    padding-left .18rem !important

// --- 禁止图片点击、禁止灯箱 ---
a:has(img),
a.gallery-item,
a[data-fancybox],
a[data-lightbox],
a[data-gallery],
img.medium-zoom-image
  pointer-events: none !important
  cursor: default !important
