// Theme base
@import '../../include/style/base'
@import '../../include/style/helper'
@import '../../include/style/button'
@import '../../include/style/card'
@import '../../include/style/article'
@import '../../include/style/navbar'
@import '../../include/style/footer'
@import '../../include/style/pagination'
@import '../../include/style/codeblock'
@import '../../include/style/widget'
@import '../../include/style/responsive'

/* ==========================
   Shared page layouts
   ========================== */
@media screen and (min-width: 1024px)
  .is-1-column .container
    max-width 1120px
    width calc(100% - 2rem)

.article .content .home-sections
  display: flex
  flex-direction row
  justify-content: space-between
  align-items: flex-start
  flex-wrap: wrap
  gap: 1em

.article .content .home-layout
  .home-main
    flex 1.5 1 28rem
  .home-news
    flex 1 1 18rem
    background #f8f9fa
    padding .3em .5em .2em
    border-radius 8px
    box-shadow 4px 4px 4px rgba(0,0,0,.05)

.article .content .member-layout
  .member-list
    flex 1 1 22rem
    text-align left
  .group-photos
    flex 1.2 1 24rem

.article .content figure
  margin .6rem 0 .8rem !important
  text-align center

.article .content figure img
  display block
  margin 0 auto

.article .content figure figcaption
  margin-top .25rem
  text-align center
  color #666
  font-size .95em
  font-style normal

.profile-photo img
  width 160px
  border-radius 50%

.research-figure img
  width 300px
  max-width 100%

.group-photo
  img
    width 1000px
    max-width 100%

.include-news
  margin 0 auto
  max-width 900px
  padding 0 .5em

.include-news-list
  margin 0 !important
  margin-left 0 !important
  padding-left 1em !important
  list-style-position outside !important

.include-news-more
  text-align center !important
  margin-top .8em !important


.article .content a
  font-weight 600


/* =====================================
   标题
   ===================================== */
.content h1
  font-size 1.2em !important
  font-weight 700 !important
  text-align left !important
  margin .45em 0 .3em 0 !important
  line-height 1.5 !important
  color #800020 !important

.content .center
  text-align center !important
  text-indent 0

.content h2
  font-size 1.1em !important
  font-weight 700
  margin .3em 0 .3em 0 !important
  text-indent 0
  line-height 1.5

.content p + h2
  margin-top .1em !important

.content h3
  font-size 1em !important
  font-weight 600
  margin .2em 0 .2em 0 !important
  text-indent 0
  line-height 1.5


/* =====================================
   正文段落
   ===================================== */
.content p
  text-indent 2em
  margin .2em 0 .2em 0
  line-height 1.5
  text-align justify
  color #222

// 若某段不需要缩进，给它加 .noindent
.content p.noindent
  text-indent 0

// 列表后的第一段不缩进（更自然）
.content ul + p,
.content ol + p
  text-indent 0


/* =====================================
   列表
   ===================================== */
.content ul,
.content ol
  margin .2em 0 .2em 2em
  line-height 1.5
  text-align left   // 列表不建议两端对齐，避免斑马纹


/* =====================================
   页脚
   ===================================== */
.footer-visitors
  margin-top .2em


/* =====================================
   强调（粗体 / 斜粗体）
   ===================================== */
.content strong,
.content b
  color #800020
  font-weight bold
  font-style normal

.content strong.normal,
.content b.normal
  color inherit

.content em strong,
.content strong em
  color #0066cc
  font-weight bold
  font-style italic

.content em strong.normal,
.content strong.normal em
  color inherit
  font-weight bold
  font-style italic


/* =====================================
   导航栏
   ===================================== */
.navbar-main .navbar-container,
.navbar-main .navbar-menu
  overflow-x visible !important

.navbar-main .navbar-menu,
.navbar-main .navbar-start,
.navbar-main .navbar-end
  flex-wrap wrap
  min-width 0

.navbar-main .navbar-item
  font-size 1rem
  white-space nowrap
  text-decoration none !important

.navbar-main .navbar-item:hover,
.navbar-main .navbar-item:focus,
.navbar-main .navbar-item.is-active
  text-decoration none !important

.navbar-item.is-active
  color #3273dc
  font-weight 600

.navbar .navbar-logo
  padding 0 .2rem 0 .45rem !important
  pointer-events auto !important

.navbar .navbar-logo img
  height 26px !important
  max-height 26px !important
  vertical-align middle

@media screen and (max-width: 768px)
  html,
  body
    overflow-x hidden

  .article .content .home-layout .home-main,
  .article .content .home-layout .home-news,
  .article .content .member-layout .member-list,
  .article .content .member-layout .group-photos
    flex 1 1 100%
    min-width 0

  .navbar-main .navbar-container,
  .navbar-main .navbar-menu
    width 100% !important
    max-width 100% !important
    overflow-x hidden !important

  .navbar-main .navbar-menu
    flex 1 1 100%
    flex-wrap wrap
    flex-shrink 1
    justify-content flex-start

  .navbar-main .navbar-start,
  .navbar-main .navbar-end
    display contents

  .navbar-main .navbar-item
    padding .32rem .32rem !important
    line-height 1.25

  .navbar .navbar-logo img
    height 22px !important
    max-height 22px !important

// --- 禁止图片点击、禁止灯箱 ---
a:has(img),
a.gallery-item,
a[data-fancybox],
a[data-lightbox],
a[data-gallery],
img.medium-zoom-image
  pointer-events: none !important
  cursor: default !important
